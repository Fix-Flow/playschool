// ─────────────────────────────────────────────────────────────
// PlaySchl — Prisma Schema
// ─────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  TEACHER
  STUDENT
  PARENT
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum FeeStatus {
  PENDING
  PAID
  PARTIAL
  OVERDUE
  WAIVED
}

enum AssignmentStatus {
  DRAFT
  PUBLISHED
  CLOSED
}

enum SubmissionStatus {
  PENDING
  SUBMITTED
  GRADED
  LATE
}

enum ExamStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum NotificationType {
  ANNOUNCEMENT
  ALERT
  REMINDER
  MESSAGE
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

// ─── Core Models ──────────────────────────────────────────────

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String
  firstName     String    @map("first_name")
  lastName      String    @map("last_name")
  role          UserRole
  phone         String?
  avatar        String?
  isActive      Boolean   @default(true) @map("is_active")
  lastLoginAt   DateTime? @map("last_login_at")
  schoolId      String?   @map("school_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Relations
  school        School?   @relation(fields: [schoolId], references: [id])
  student       Student?
  teacher       Teacher?
  parent        Parent?
  notifications UserNotification[]

  @@map("users")
}

model School {
  id            String    @id @default(uuid())
  name          String
  code          String    @unique
  address       String?
  phone         String?
  email         String?
  logo          String?
  website       String?
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Relations
  users         User[]
  classes       Class[]
  subjects      Subject[]
  academicYears AcademicYear[]
  feeStructures FeeStructure[]

  @@map("schools")
}

// ─── People Models ────────────────────────────────────────────

model Student {
  id              String    @id @default(uuid())
  userId          String    @unique @map("user_id")
  admissionNumber String    @unique @map("admission_number")
  dateOfBirth     DateTime  @map("date_of_birth")
  gender          Gender
  bloodGroup      String?   @map("blood_group")
  address         String?
  classId         String?   @map("class_id")
  sectionId       String?   @map("section_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  class           Class?    @relation(fields: [classId], references: [id])
  section         Section?  @relation(fields: [sectionId], references: [id])
  attendances     Attendance[]
  submissions     AssignmentSubmission[]
  examResults     ExamResult[]
  feePayments     FeePayment[]
  parentStudents  ParentStudent[]

  @@map("students")
}

model Teacher {
  id              String    @id @default(uuid())
  userId          String    @unique @map("user_id")
  employeeId      String    @unique @map("employee_id")
  dateOfBirth     DateTime? @map("date_of_birth")
  gender          Gender?
  qualification   String?
  experience      Int?      // Years
  specialization  String?
  dateOfJoining   DateTime  @map("date_of_joining")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  classTeacher    Class?    @relation("ClassTeacher")
  subjectTeachers SubjectTeacher[]
  timetableSlots  TimetableSlot[]
  assignments     Assignment[]
  exams           Exam[]

  @@map("teachers")
}

model Parent {
  id              String    @id @default(uuid())
  userId          String    @unique @map("user_id")
  occupation      String?
  relationship    String?   // Father, Mother, Guardian
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentStudents  ParentStudent[]

  @@map("parents")
}

model ParentStudent {
  id        String  @id @default(uuid())
  parentId  String  @map("parent_id")
  studentId String  @map("student_id")

  parent    Parent  @relation(fields: [parentId], references: [id], onDelete: Cascade)
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([parentId, studentId])
  @@map("parent_students")
}

// ─── Academic Structure ───────────────────────────────────────

model AcademicYear {
  id        String    @id @default(uuid())
  name      String    // e.g., "2024-2025"
  startDate DateTime  @map("start_date")
  endDate   DateTime  @map("end_date")
  isCurrent Boolean   @default(false) @map("is_current")
  schoolId  String    @map("school_id")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  school    School    @relation(fields: [schoolId], references: [id])
  timetables Timetable[]
  exams     Exam[]

  @@map("academic_years")
}

model Class {
  id            String    @id @default(uuid())
  name          String    // e.g., "Grade 10"
  grade         Int
  schoolId      String    @map("school_id")
  classTeacherId String?  @unique @map("class_teacher_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Relations
  school        School    @relation(fields: [schoolId], references: [id])
  classTeacher  Teacher?  @relation("ClassTeacher", fields: [classTeacherId], references: [id])
  sections      Section[]
  students      Student[]
  subjects      SubjectTeacher[]
  timetables    Timetable[]
  assignments   Assignment[]
  feeStructures FeeStructure[]

  @@map("classes")
}

model Section {
  id        String    @id @default(uuid())
  name      String    // e.g., "A", "B"
  classId   String    @map("class_id")
  capacity  Int       @default(40)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  class     Class     @relation(fields: [classId], references: [id])
  students  Student[]

  @@unique([classId, name])
  @@map("sections")
}

model Subject {
  id        String    @id @default(uuid())
  name      String
  code      String    @unique
  schoolId  String    @map("school_id")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  school    School    @relation(fields: [schoolId], references: [id])
  teachers  SubjectTeacher[]
  assignments Assignment[]
  exams     Exam[]

  @@map("subjects")
}

model SubjectTeacher {
  id        String  @id @default(uuid())
  subjectId String  @map("subject_id")
  teacherId String  @map("teacher_id")
  classId   String  @map("class_id")

  subject   Subject @relation(fields: [subjectId], references: [id])
  teacher   Teacher @relation(fields: [teacherId], references: [id])
  class     Class   @relation(fields: [classId], references: [id])

  @@unique([subjectId, teacherId, classId])
  @@map("subject_teachers")
}

// ─── Attendance ───────────────────────────────────────────────

model Attendance {
  id        String           @id @default(uuid())
  studentId String           @map("student_id")
  date      DateTime
  status    AttendanceStatus
  remarks   String?
  markedBy  String           @map("marked_by")
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  student   Student          @relation(fields: [studentId], references: [id])

  @@unique([studentId, date])
  @@map("attendances")
}

// ─── Timetable ────────────────────────────────────────────────

model Timetable {
  id             String    @id @default(uuid())
  classId        String    @map("class_id")
  academicYearId String    @map("academic_year_id")
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  class          Class     @relation(fields: [classId], references: [id])
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])
  slots          TimetableSlot[]

  @@map("timetables")
}

model TimetableSlot {
  id          String    @id @default(uuid())
  timetableId String    @map("timetable_id")
  dayOfWeek   DayOfWeek @map("day_of_week")
  startTime   String    @map("start_time") // HH:mm
  endTime     String    @map("end_time")   // HH:mm
  subjectId   String?   @map("subject_id")
  teacherId   String?   @map("teacher_id")
  room        String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  timetable   Timetable @relation(fields: [timetableId], references: [id], onDelete: Cascade)
  teacher     Teacher?  @relation(fields: [teacherId], references: [id])

  @@map("timetable_slots")
}

// ─── Assignments ──────────────────────────────────────────────

model Assignment {
  id          String           @id @default(uuid())
  title       String
  description String?
  subjectId   String           @map("subject_id")
  classId     String           @map("class_id")
  teacherId   String           @map("teacher_id")
  dueDate     DateTime         @map("due_date")
  maxMarks    Int?             @map("max_marks")
  status      AssignmentStatus @default(DRAFT)
  attachments String[]
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  subject     Subject          @relation(fields: [subjectId], references: [id])
  class       Class            @relation(fields: [classId], references: [id])
  teacher     Teacher          @relation(fields: [teacherId], references: [id])
  submissions AssignmentSubmission[]

  @@map("assignments")
}

model AssignmentSubmission {
  id           String           @id @default(uuid())
  assignmentId String           @map("assignment_id")
  studentId    String           @map("student_id")
  content      String?
  attachments  String[]
  status       SubmissionStatus @default(PENDING)
  marks        Int?
  feedback     String?
  submittedAt  DateTime?        @map("submitted_at")
  gradedAt     DateTime?        @map("graded_at")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  assignment   Assignment       @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student      Student          @relation(fields: [studentId], references: [id])

  @@unique([assignmentId, studentId])
  @@map("assignment_submissions")
}

// ─── Exams & Results ──────────────────────────────────────────

model Exam {
  id             String     @id @default(uuid())
  name           String
  subjectId      String     @map("subject_id")
  teacherId      String     @map("teacher_id")
  academicYearId String     @map("academic_year_id")
  examDate       DateTime   @map("exam_date")
  startTime      String?    @map("start_time")
  endTime        String?    @map("end_time")
  totalMarks     Int        @map("total_marks")
  passingMarks   Int        @map("passing_marks")
  status         ExamStatus @default(SCHEDULED)
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  subject        Subject    @relation(fields: [subjectId], references: [id])
  teacher        Teacher    @relation(fields: [teacherId], references: [id])
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])
  results        ExamResult[]

  @@map("exams")
}

model ExamResult {
  id          String    @id @default(uuid())
  examId      String    @map("exam_id")
  studentId   String    @map("student_id")
  marksObtained Int     @map("marks_obtained")
  grade       String?
  remarks     String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  exam        Exam      @relation(fields: [examId], references: [id], onDelete: Cascade)
  student     Student   @relation(fields: [studentId], references: [id])

  @@unique([examId, studentId])
  @@map("exam_results")
}

// ─── Fees ─────────────────────────────────────────────────────

model FeeStructure {
  id        String    @id @default(uuid())
  name      String
  amount    Float
  classId   String    @map("class_id")
  schoolId  String    @map("school_id")
  dueDate   DateTime  @map("due_date")
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  class     Class     @relation(fields: [classId], references: [id])
  school    School    @relation(fields: [schoolId], references: [id])
  payments  FeePayment[]

  @@map("fee_structures")
}

model FeePayment {
  id             String    @id @default(uuid())
  studentId      String    @map("student_id")
  feeStructureId String    @map("fee_structure_id")
  amountPaid     Float     @map("amount_paid")
  status         FeeStatus @default(PENDING)
  paymentDate    DateTime? @map("payment_date")
  paymentMethod  String?   @map("payment_method")
  transactionId  String?   @map("transaction_id")
  receiptNumber  String?   @map("receipt_number")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  student        Student   @relation(fields: [studentId], references: [id])
  feeStructure   FeeStructure @relation(fields: [feeStructureId], references: [id])

  @@map("fee_payments")
}

// ─── Notifications ────────────────────────────────────────────

model Notification {
  id        String           @id @default(uuid())
  title     String
  message   String
  type      NotificationType @default(ANNOUNCEMENT)
  senderId  String           @map("sender_id")
  isGlobal  Boolean          @default(false) @map("is_global")
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  recipients UserNotification[]

  @@map("notifications")
}

model UserNotification {
  id             String       @id @default(uuid())
  userId         String       @map("user_id")
  notificationId String       @map("notification_id")
  isRead         Boolean      @default(false) @map("is_read")
  readAt         DateTime?    @map("read_at")
  createdAt      DateTime     @default(now()) @map("created_at")

  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@unique([userId, notificationId])
  @@map("user_notifications")
}
